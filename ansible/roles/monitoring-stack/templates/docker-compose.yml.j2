services:
  prometheus:
    image: prom/prometheus:v3.13.1
    container_name: prometheus
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml
      - prometheus-data:/prometheus
    ports:
      - "9090:9090"
    restart: unless-stopped

  pve-exporter:
    image: prompve/prometheus-pve-exporter:3.9.0
    container_name: pve-exporter
    volumes:
      - ./pve-exporter.yml:/etc/prometheus/pve.yml
    ports:
      - "9221:9221"
    restart: unless-stopped

  unpoller:
    image: ghcr.io/unpoller/unpoller:v3.3.3
    container_name: unpoller
    environment:
      UP_UNIFI_DEFAULT_URL: "https://10.15.30.1"
      UP_UNIFI_DEFAULT_USER: "{{ unifi_unpoller_user }}"
      UP_UNIFI_DEFAULT_PASS: "{{ unifi_unpoller_pass }}"
      UP_UNIFI_DEFAULT_VERIFY_SSL: "false"
      UP_PROMETHEUS_HTTP_LISTEN: "0.0.0.0:9130"
      UP_INFLUXDB_DISABLE: "true"
    ports:
      - "9130:9130"
    restart: unless-stopped

  grafana:
    image: grafana/grafana:13.1.1
    container_name: grafana
    volumes:
      - grafana-data:/var/lib/grafana
    ports:
      - "3000:3000"
    restart: unless-stopped

  kromgo:
    image: ghcr.io/home-operations/kromgo:0.15.1
    container_name: kromgo
    volumes:
      - ./kromgo.yaml:/config/config.yaml:ro
    environment:
      KROMGO_PROMETHEUS_URL: http://prometheus:9090
    ports:
      - "8080:8080"
    restart: unless-stopped

volumes:
  prometheus-data:
  grafana-data:
